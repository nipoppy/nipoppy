# OpenTelemetry Configuration for Nipoppy
# Copy this file to .env and customize as needed

# ==============================================================================
# TELEMETRY SETTINGS
# ==============================================================================

# OpenTelemetry Collector endpoint
# Default: localhost:4317 (local demo setup)
# Production: Set to your collector's address
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Service name for telemetry
# This appears in metrics as the "service_name" label
OTEL_SERVICE_NAME=nipoppy

# Disable telemetry completely
# Set to "true" to disable all OpenTelemetry instrumentation
# Default: false (telemetry enabled)
OTEL_SDK_DISABLED=false

# Deployment environment
# Used to tag metrics with environment (development, staging, production)
# Default: development
ENVIRONMENT=development

# ==============================================================================
# FUTURE: GEOIP SETTINGS (for country tracking)
# ==============================================================================

# Path to MaxMind GeoLite2 Country database
# Download from: https://www.maxmind.com/en/geolite2/signup
# Or: wget https://github.com/P3TERX/GeoLite.mmdb/raw/download/GeoLite2-Country.mmdb
# GEOIP_DB_PATH=/path/to/GeoLite2-Country.mmdb

# ==============================================================================
# NOTES
# ==============================================================================

# To use this file:
# 1. Copy to .env: cp .env.example .env
# 2. Customize values as needed
# 3. Source before running nipoppy: source .env && nipoppy init /path/to/dataset
#
# Or use with docker-compose:
# - Add env_file: [".env"] to docker-compose.yml services

# ==============================================================================
# EXAMPLES
# ==============================================================================

# Disable telemetry for testing:
# OTEL_SDK_DISABLED=true

# Use remote collector:
# OTEL_EXPORTER_OTLP_ENDPOINT=collector.example.com:4317

# Production environment:
# ENVIRONMENT=production
# OTEL_SERVICE_NAME=nipoppy-prod
