{
  "title": "Nipoppy Telemetry",
  "uid": "nipoppy-telemetry",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "nipoppy"
  ],
  "editable": true,
  "panels": [
    {
      "id": 10,
      "type": "row",
      "title": "All-Time Totals",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Inits",
      "description": "All nipoppy init runs ever received by this server",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nipoppy_commands_executed_total{command=\"init\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Commands",
      "description": "All nipoppy commands ever run across all users",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(nipoppy_commands_executed_total)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Success Rate",
      "description": "Percentage of commands that completed successfully (all time)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "100 * sum(nipoppy_commands_completed_total{status=\"success\"}) / sum(nipoppy_commands_completed_total)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unique Commands Seen",
      "description": "How many distinct nipoppy commands have been used at least once",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(sum by (command) (nipoppy_commands_executed_total))",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Command Breakdown  (time range controlled by picker above)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "table",
      "title": "Invocations per Command",
      "description": "Total runs per command. Sorted by most used.",
      "gridPos": {
        "h": 10,
        "w": 10,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (command) (nipoppy_commands_executed_total))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "command"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Command"
              },
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Total Runs"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "deployment_environment": true,
              "exported_job": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_version": true,
              "otel_scope_name": true,
              "otel_scope_schema_url": true,
              "otel_scope_version": true
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Command Distribution",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 10,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (command) (nipoppy_commands_executed_total)",
          "legendFormat": "{{command}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "name",
          "value"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Status per Command  (success / partial / failure)",
      "description": "How each command completed. Status text is color-coded.",
      "gridPos": {
        "h": 10,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (command, status) (nipoppy_commands_completed_total)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "desc": true,
            "displayName": "Count"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "command"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Command"
              },
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Status"
              },
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "success": {
                        "text": "success",
                        "color": "green",
                        "index": 0
                      },
                      "partial": {
                        "text": "partial",
                        "color": "yellow",
                        "index": 1
                      },
                      "failure": {
                        "text": "failure",
                        "color": "red",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Count"
              },
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "deployment_environment": true,
              "exported_job": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_version": true,
              "otel_scope_name": true,
              "otel_scope_schema_url": true,
              "otel_scope_version": true
            }
          }
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Geographic Distribution",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "table",
      "title": "Installations by Country",
      "description": "Total nipoppy init runs per country (ISO 2-letter code).",
      "gridPos": {
        "h": 10,
        "w": 10,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (country) (nipoppy_location_by_country_installations_total))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "country"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Country"
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Installations"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "deployment_environment": true,
              "exported_job": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_version": true,
              "otel_scope_name": true,
              "otel_scope_schema_url": true,
              "otel_scope_version": true
            }
          }
        }
      ]
    },
    {
      "id": 32,
      "type": "piechart",
      "title": "Init Distribution by Country",
      "description": "Share of nipoppy init runs per country.",
      "gridPos": {
        "h": 10,
        "w": 14,
        "x": 10,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (country) (nipoppy_location_by_country_installations_total)",
          "legendFormat": "{{country}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "name",
          "value"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0
        },
        "overrides": []
      }
    }
  ]
}